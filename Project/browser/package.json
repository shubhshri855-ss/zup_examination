{
  "name": "samadhan-secure-browser",
  "version": "1.0.0",
  "description": "SAMADHAN Secure Exam Browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.6.8"
  },
  "devDependencies": {
    "electron": "^29.1.5",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.samadhan.securebrowser",
    "productName": "SAMADHAN Secure Exam Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "ui.js",
      "index.html",
      "package.json"
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName} Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName} Portable.${ext}"
    }
  }
}
